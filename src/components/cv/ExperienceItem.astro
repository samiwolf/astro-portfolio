---
interface Props {
  company: string;
  location: string;
  position: string;
  period: string;
  responsibilities: string[];
  projects: Array<{
    name: string;
    description: string;
  }>;
}

const { company, location, position, period, responsibilities, projects } = Astro.props;
---

<div class="space-y-6 mb-4">
  <div class="flex flex-col sm:flex-row sm:justify-between sm:items-start mb-4">
    <div>
      <h4 class="text-xl font-semibold text-gray-900">{company}</h4>
      <p class="text-gray-600">{position}</p>
      <p class="text-sm text-gray-500">{location}</p>
    </div>
    <span class="text-sm font-medium text-blue-600 bg-blue-50 px-3 py-1 rounded-full mt-2 sm:mt-0">
      {period}
    </span>
  </div>

  <div>
    <h5 class="font-semibold text-gray-800 mb-3">Key Responsibilities:</h5>
    <ul class="space-y-2">
      {responsibilities.map((responsibility) => (
        <li class="flex items-start">
          <span class="text-blue-500 mt-1 mr-2 flex-shrink-0">•</span>
          <span class="text-gray-700 text-sm leading-relaxed">{responsibility}</span>
        </li>
      ))}
    </ul>
  </div>

  {projects.length > 0 && (
    <div>
      <h5 class="font-semibold text-gray-800 mb-3">Notable Projects:</h5>
      <div class="space-y-3">
        {projects.map((project) => (
          <div class="bg-gray-50 rounded-lg p-4 border-l-4 border-blue-500">
            <h6 class="font-medium text-gray-900 mb-1">{project.name}</h6>
            <p class="text-sm text-gray-600">{project.description}</p>
          </div>
        ))}
      </div>
    </div>
  )}
</div>
