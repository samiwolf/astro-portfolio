---
interface Props {
  institution: string;
  location: string;
  degree: string;
  period: string;
  cgpa?: string;
}

const { institution, location, degree, period, cgpa } = Astro.props;
---

<div class="flex flex-col sm:flex-row sm:justify-between sm:items-start">
  <div>
    <h4 class="text-lg font-semibold text-gray-900">{institution}</h4>
    <p class="text-gray-700 font-medium">{degree}</p>
    <p class="text-sm text-gray-500">{location}</p>
  </div>
  <div class="mt-2 sm:mt-0 text-right">
    <span class="text-sm font-medium text-blue-600 bg-blue-50 px-3 py-1 rounded-full block">
      {period}
    </span>
    {cgpa && (
      <span class="text-sm text-gray-600 mt-1 block">
        CGPA: {cgpa}
      </span>
    )}
  </div>
</div>
